root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
max_line_length = 120
indent_size = 4
indent_style = space

# ktlint specific rules
ktlint_code_style = android_studio

# Import ordering: android → com.falconlabs → third-party → kotlin → java
ktlint_standard_import-ordering = enabled
ij_kotlin_imports_layout = android.**,androidx.**,|,com.falconlabs.**,|,*,|,kotlin.**,kotlinx.**,|,java.**,javax.**

# No wildcard imports
ij_kotlin_name_count_to_use_star_import = 999
ij_kotlin_name_count_to_use_star_import_for_members = 999
ij_kotlin_packages_to_use_import_on_demand = unset

# Wrapping
ij_kotlin_wrap_on_typing = true
ij_continuation_indent_size = 4

# Function signature: force multiline when exceeds max line length
ktlint_function_signature_rule_force_multiline_when_parameter_count_greater_or_equal_than = 3

# Allow trailing commas (recommended for Kotlin)
ktlint_standard_trailing-comma-on-call-site = disabled
ktlint_standard_trailing-comma-on-declaration-site = disabled

# Compose-specific: allow composable function names to start with uppercase
ktlint_function_naming_ignore_when_annotated_with = Composable

# Disable filename rule (main.kt, build.gradle.kts etc. don't follow PascalCase)
ktlint_standard_filename = disabled

# Blank line rules
ktlint_standard_no-blank-line-in-list = enabled
ktlint_standard_no-consecutive-blank-lines = enabled

# String template rules
ktlint_standard_string-template = enabled

[*.xml]
indent_size = 4

[*.{yaml,yml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{json,toml}]
indent_size = 2
